---
const corePackages = [
  { name: "@hiveio/wax", desc: "Core library — transactions, validation, formatting", npm: "https://www.npmjs.com/package/@hiveio/wax" },
  { name: "signers-beekeeper", desc: "Sign with Hive Beekeeper wallet", npm: "https://www.npmjs.com/package/@hiveio/signers-beekeeper" },
  { name: "signers-keychain", desc: "Sign with Hive Keychain extension", npm: "https://www.npmjs.com/package/@hiveio/signers-keychain" },
  { name: "signers-metamask", desc: "Sign with MetaMask Snap", npm: "https://www.npmjs.com/package/@hiveio/signers-metamask" },
  { name: "signers-peakvault", desc: "Sign with PeakVault extension", npm: "https://www.npmjs.com/package/@hiveio/signers-peakvault" },
];

const signerPackages = [
  { name: "@hiveio/signers-hb-auth", desc: "Hb-auth service worker signer", npm: "https://www.npmjs.com/package/@hiveio/signers-hb-auth" },
  { name: "@hiveio/signers-external", desc: "Google Drive wallet signer", npm: "https://www.npmjs.com/package/@hiveio/signers-external" },
];

const apiPackages = [
  { name: "@hiveio/wax-api-jsonrpc", desc: "Full JSON-RPC API hived node definitions", npm: "https://www.npmjs.com/package/@hiveio/wax-api-jsonrpc" },
  { name: "@hiveio/wax-api-hafbe", desc: "Full Block Explorer REST API definitions", npm: "https://www.npmjs.com/package/@hiveio/wax-api-hafbe" },
  { name: "@hiveio/wax-api-reputation-tracker", desc: "Full Reputation Tracker REST API definitions", npm: "https://www.npmjs.com/package/@hiveio/wax-api-reputation-tracker" },
  { name: "@hiveio/wax-api-balance-tracker", desc: "Full Balance Tracker REST API definitions", npm: "https://www.npmjs.com/package/@hiveio/wax-api-balance-tracker" },
  { name: "@hiveio/wax-api-hafah", desc: "Full Account History REST API definitions", npm: "https://www.npmjs.com/package/@hiveio/wax-api-hafah" },
];
---

<section id="ecosystem" class="min-h-dvh flex flex-col justify-center py-24 max-md:py-16" aria-labelledby="ecosystem-heading">
  <div class="mx-auto max-w-[1120px] px-6">
    <h2 id="ecosystem-heading" data-animate class="font-display text-[40px] max-md:text-[28px] leading-[1.2] text-text-primary mb-16">
      Ecosystem
    </h2>

    <!-- Core -->
    <div data-animate class="mb-12">
      <h3 class="text-[13px] uppercase tracking-[0.05em] text-text-tertiary font-display mb-6">Core</h3>
      <div class="flex flex-wrap gap-0 max-md:flex-col">
        {corePackages.map((pkg, i) => (
          <div class={`border-l-2 pl-4 py-3 pr-8 max-md:pr-0 ${i === 0 ? "border-l-accent" : "border-l-border"}`}>
            <a href={pkg.npm} target="_blank" rel="noopener noreferrer" class="text-accent font-body text-[15px] mb-1 hover:text-accent-hover transition-colors">{pkg.name}</a>
            <p class="text-text-secondary text-[13px]">{pkg.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Signers -->
    <div data-animate class="mb-12">
      <h3 class="text-[13px] uppercase tracking-[0.05em] text-text-tertiary font-display mb-6">Signers</h3>
      <div class="flex flex-wrap gap-0 max-md:flex-col">
        {signerPackages.map((pkg) => (
          <div class="border-l-2 border-l-border pl-4 py-3 pr-8 max-md:pr-0">
            <a href={pkg.npm} target="_blank" rel="noopener noreferrer" class="text-accent font-body text-[15px] mb-1 hover:text-accent-hover transition-colors">{pkg.name}</a>
            <p class="text-text-secondary text-[13px]">{pkg.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- API Definitions -->
    <div data-animate>
      <h3 class="text-[13px] uppercase tracking-[0.05em] text-text-tertiary font-display mb-6">API Definitions</h3>
      <div class="flex flex-wrap gap-0 max-md:flex-col">
        {apiPackages.map((pkg) => (
          <div class="border-l-2 border-l-border pl-4 py-3 pr-8 max-md:pr-0">
            <a href={pkg.npm} target="_blank" rel="noopener noreferrer" class="text-accent font-body text-[15px] mb-1 hover:text-accent-hover transition-colors">{pkg.name}</a>
            <p class="text-text-secondary text-[13px]">{pkg.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
