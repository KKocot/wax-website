---
interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  features: Feature[];
}

const { features } = Astro.props;
---

<section id="features" class="min-h-dvh flex flex-col justify-center bg-bg-secondary py-24 max-md:py-16" aria-labelledby="features-heading">
  <div class="mx-auto max-w-[1120px] px-6">
    <h2 id="features-heading" data-animate class="font-display text-[40px] max-md:text-[28px] leading-[1.2] text-text-primary text-center mb-12">Features</h2>
    <div class="grid grid-cols-3 max-lg:grid-cols-2 max-sm:grid-cols-1 gap-4">
      {features.map((feature, i) => (
        <div
          data-animate
          style={`transition-delay: ${i * 50}ms`}
          class="bg-surface border border-border rounded-[8px] p-6 hover:border-border-hover hover:bg-surface-hover transition-all duration-200"
        >
          <div class="w-10 h-10 bg-surface rounded-[6px] flex items-center justify-center text-accent font-display text-[16px] font-medium mb-4 border border-border">
            {feature.icon}
          </div>
          <h3 class="text-text-primary font-display text-[18px] leading-[1.4] mb-2">{feature.title}</h3>
          <p class="text-text-secondary text-[15px] leading-[1.6]">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
