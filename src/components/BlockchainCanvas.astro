---
// Blockchain grid canvas background — animated node network
---

<canvas id="bg-canvas" style="position:fixed;inset:0;z-index:0;pointer-events:none;" aria-hidden="true"></canvas>

<script>
  (function () {
    const canvas = /** @type {HTMLCanvasElement} */ (document.getElementById('bg-canvas'));
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Configuration
    const SPACING = 100;
    const MAX_NODES = 150;
    const NODE_RADIUS = 1.5;
    const CONNECTION_DISTANCE = 140;
    const CONNECTION_DISTANCE_SQ = CONNECTION_DISTANCE * CONNECTION_DISTANCE;
    const NODE_OPACITY_MIN = 0.15;
    const NODE_OPACITY_MAX = 0.25;
    const LINE_OPACITY = 0.06;
    const DRIFT_AMPLITUDE = 20;
    const PULSE_SPEED = 0.0008;

    /** @typedef {{ baseX: number; baseY: number; x: number; y: number; driftX: number; driftY: number; speedX: number; speedY: number; phaseX: number; phaseY: number; pulsePhase: number; pulseSpeed: number }} Node */

    /** @type {Node[]} */
    let nodes = [];
    let w = 0;
    let h = 0;
    let animId = 0;

    // Cleanup controller for resize listener
    const abortController = new AbortController();

    function resize() {
      // Cancel previous animation frame before rebuilding
      cancelAnimationFrame(animId);

      const dpr = window.devicePixelRatio || 1;
      w = window.innerWidth;
      h = window.innerHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      createNodes();

      // Restart animation loop after rebuild
      if (reducedMotion) {
        draw(0);
      } else {
        animId = requestAnimationFrame(draw);
      }
    }

    function createNodes() {
      nodes = [];
      // Dynamic spacing: guarantee node count stays within MAX_NODES
      const effectiveSpacing = Math.max(SPACING, Math.sqrt((w * h) / MAX_NODES));
      const cols = Math.ceil(w / effectiveSpacing) + 2;
      const rows = Math.ceil(h / effectiveSpacing) + 2;
      const offsetX = ((w - (cols - 1) * effectiveSpacing) / 2);
      const offsetY = ((h - (rows - 1) * effectiveSpacing) / 2);

      for (let row = 0; row < rows; row++) {
        for (let col = 0; col < cols; col++) {
          const baseX = offsetX + col * effectiveSpacing;
          const baseY = offsetY + row * effectiveSpacing;

          nodes.push({
            baseX,
            baseY,
            x: baseX,
            y: baseY,
            driftX: (Math.random() - 0.5) * DRIFT_AMPLITUDE * 2,
            driftY: (Math.random() - 0.5) * DRIFT_AMPLITUDE * 2,
            speedX: 0.0003 + Math.random() * 0.0006,
            speedY: 0.0003 + Math.random() * 0.0006,
            phaseX: Math.random() * Math.PI * 2,
            phaseY: Math.random() * Math.PI * 2,
            pulsePhase: Math.random() * Math.PI * 2,
            pulseSpeed: PULSE_SPEED + (Math.random() - 0.5) * 0.0004,
          });
        }
      }
    }

    /** @param {number} now */
    function draw(now) {
      ctx.clearRect(0, 0, w, h);

      // Update positions (skip if reduced motion)
      if (!reducedMotion) {
        for (let i = 0; i < nodes.length; i++) {
          const n = nodes[i];
          n.x = n.baseX + Math.sin(now * n.speedX + n.phaseX) * n.driftX;
          n.y = n.baseY + Math.cos(now * n.speedY + n.phaseY) * n.driftY;
        }
      }

      // Draw connections — batched into a single path with uniform alpha
      ctx.lineWidth = 1;
      ctx.strokeStyle = 'rgb(245, 158, 11)';
      ctx.globalAlpha = LINE_OPACITY;
      ctx.beginPath();
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          const distSq = dx * dx + dy * dy;

          if (distSq < CONNECTION_DISTANCE_SQ) {
            ctx.moveTo(nodes[i].x, nodes[i].y);
            ctx.lineTo(nodes[j].x, nodes[j].y);
          }
        }
      }
      ctx.stroke();

      // Draw nodes — batched into a single path with averaged opacity
      const avgNodeOpacity = (NODE_OPACITY_MIN + NODE_OPACITY_MAX) / 2;
      ctx.fillStyle = 'rgb(245, 158, 11)';
      ctx.globalAlpha = avgNodeOpacity;
      ctx.beginPath();
      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        ctx.moveTo(n.x + NODE_RADIUS, n.y);
        ctx.arc(n.x, n.y, NODE_RADIUS, 0, Math.PI * 2);
      }
      ctx.fill();

      // Reset globalAlpha
      ctx.globalAlpha = 1;

      if (!reducedMotion) {
        animId = requestAnimationFrame(draw);
      }
    }

    // Cleanup function for navigation / unmount
    function cleanup() {
      cancelAnimationFrame(animId);
      abortController.abort();
      document.removeEventListener('astro:before-swap', cleanup);
    }

    // Throttled resize with AbortController
    let resizeTimer = 0;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(resize, 150);
    }, { signal: abortController.signal });

    // Cleanup on Astro page navigation
    document.addEventListener('astro:before-swap', cleanup);

    // Initialize
    resize();
  })();
</script>
