---
interface Props {
  description: string;
  links: { docs: string; gitlab: string };
}

const { description, links } = Astro.props;
---

<section class="min-h-dvh flex flex-col justify-center pt-32 pb-24 max-md:pt-24 max-md:pb-16" aria-labelledby="hero-heading">
  <div class="mx-auto max-w-[1120px] px-6 w-full">
    <div class="grid grid-cols-2 gap-12 items-center max-md:grid-cols-1 max-md:gap-10">

      <!-- Left column — text -->
      <div class="max-md:text-center max-md:flex max-md:flex-col max-md:items-center">
        <div data-animate style="transition-delay: 0ms">
          <a href={links.gitlab} target="_blank" rel="noopener noreferrer" class="inline-block bg-accent-subtle text-accent border border-accent/20 text-[13px] font-display px-3 py-1 rounded-[4px] mb-8 hover:bg-accent/10 transition-colors">
            Open Source &mdash; MIT License
          </a>
        </div>

        <h1 id="hero-heading" data-animate style="transition-delay: 75ms" class="font-display text-[56px] max-lg:text-[44px] max-md:text-[32px] leading-[1.1] tracking-[-0.03em] text-text-primary mb-6">
          <span class="hero-heading-accent">Wax</span> — Build on Hive<br />with confidence.
        </h1>

        <p data-animate style="transition-delay: 150ms" class="text-text-secondary text-[17px] leading-[1.6] max-w-lg mb-8">
          One C++ core. Two runtimes. Full type safety.
        </p>

        <div data-animate style="transition-delay: 225ms" class="flex items-center gap-3 max-md:justify-center">
          <a href={links.docs} target="_blank" rel="noopener noreferrer" class="bg-accent text-bg-primary font-display text-sm px-5 py-2.5 rounded-[6px] hover:bg-accent-hover transition-colors">
            Read the Docs
          </a>
          <a href={links.gitlab} target="_blank" rel="noopener noreferrer" class="border border-border text-text-primary font-display text-sm px-5 py-2.5 rounded-[6px] hover:bg-surface transition-colors">
            View on GitLab
          </a>
        </div>
      </div>

      <!-- Right column — install cards -->
      <div data-animate style="transition-delay: 300ms" class="flex flex-col gap-3 max-md:w-full">
        <div class="relative bg-surface border border-border rounded-[8px] p-3">
          <p class="text-[11px] uppercase tracking-[0.05em] text-text-tertiary font-display mb-1.5">TypeScript</p>
          <pre class="text-[13px] font-body text-text-primary pr-8"><code><span class="text-text-tertiary">$</span> pnpm add @hiveio/wax</code></pre>
          <button
            class="copy-btn absolute top-2.5 right-2.5 w-7 h-7 flex items-center justify-center text-text-tertiary hover:text-text-secondary transition-colors rounded-[4px] hover:bg-surface-hover cursor-pointer"
            aria-label="Copy TypeScript install command"
            data-copy="pnpm add @hiveio/wax"
          >
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5.5" y="5.5" width="8" height="8" rx="1.5"></rect>
              <path d="M10.5 5.5V3.5C10.5 2.67 9.83 2 9 2H3.5C2.67 2 2 2.67 2 3.5V9C2 9.83 2.67 10.5 3.5 10.5H5.5"></path>
            </svg>
          </button>
        </div>
        <div class="relative bg-surface border border-border rounded-[8px] p-3">
          <p class="text-[11px] uppercase tracking-[0.05em] text-text-tertiary font-display mb-1.5">Python</p>
          <pre class="text-[13px] font-body text-text-primary pr-8"><code><span class="text-text-tertiary">$</span> pip install hiveio-wax</code></pre>
          <button
            class="copy-btn absolute top-2.5 right-2.5 w-7 h-7 flex items-center justify-center text-text-tertiary hover:text-text-secondary transition-colors rounded-[4px] hover:bg-surface-hover cursor-pointer"
            aria-label="Copy Python install command"
            data-copy="pip install hiveio-wax"
          >
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5.5" y="5.5" width="8" height="8" rx="1.5"></rect>
              <path d="M10.5 5.5V3.5C10.5 2.67 9.83 2 9 2H3.5C2.67 2 2 2.67 2 3.5V9C2 9.83 2.67 10.5 3.5 10.5H5.5"></path>
            </svg>
          </button>
        </div>
      </div>

    </div>
  </div>
</section>
