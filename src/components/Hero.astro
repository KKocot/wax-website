---
interface Props {
  description: string;
}

const { description } = Astro.props;
---

<section class="min-h-dvh flex flex-col justify-center pt-32 pb-24 max-md:pt-24 max-md:pb-16" aria-labelledby="hero-heading">
  <div class="mx-auto max-w-[720px] px-6 text-center">
    <div data-animate>
      <span class="inline-block bg-accent-subtle text-accent border border-accent/20 text-[13px] font-display px-3 py-1 rounded-[4px] mb-8">
        Open Source &mdash; MIT License
      </span>
    </div>
    <h1 id="hero-heading" data-animate class="font-display text-[64px] max-md:text-[36px] leading-[1.1] tracking-[-0.03em] text-text-primary mb-6">
      Build on Hive<br />with confidence
    </h1>
    <p data-animate class="text-text-secondary text-[15px] leading-[1.6] max-w-lg mx-auto mb-10">
      {description}
    </p>
    <div data-animate class="grid grid-cols-2 max-sm:grid-cols-1 gap-4 max-w-md mx-auto">
      <div class="relative bg-surface border border-border rounded-[8px] p-4">
        <p class="text-[11px] uppercase tracking-[0.05em] text-text-tertiary font-display mb-2">TypeScript</p>
        <pre class="text-[13px] font-body text-text-primary pr-10"><code>pnpm add @hiveio/wax</code></pre>
        <button
          class="copy-btn absolute top-3 right-3 w-8 h-8 flex items-center justify-center text-text-tertiary hover:text-text-secondary transition-colors rounded-[4px] hover:bg-surface-hover cursor-pointer"
          aria-label="Copy TypeScript install command"
          data-copy="pnpm add @hiveio/wax"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="5.5" y="5.5" width="8" height="8" rx="1.5"></rect>
            <path d="M10.5 5.5V3.5C10.5 2.67 9.83 2 9 2H3.5C2.67 2 2 2.67 2 3.5V9C2 9.83 2.67 10.5 3.5 10.5H5.5"></path>
          </svg>
        </button>
      </div>
      <div class="relative bg-surface border border-border rounded-[8px] p-4">
        <p class="text-[11px] uppercase tracking-[0.05em] text-text-tertiary font-display mb-2">Python</p>
        <pre class="text-[13px] font-body text-text-primary pr-10"><code>pip install hiveio-wax</code></pre>
        <button
          class="copy-btn absolute top-3 right-3 w-8 h-8 flex items-center justify-center text-text-tertiary hover:text-text-secondary transition-colors rounded-[4px] hover:bg-surface-hover cursor-pointer"
          aria-label="Copy Python install command"
          data-copy="pip install hiveio-wax"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="5.5" y="5.5" width="8" height="8" rx="1.5"></rect>
            <path d="M10.5 5.5V3.5C10.5 2.67 9.83 2 9 2H3.5C2.67 2 2 2.67 2 3.5V9C2 9.83 2.67 10.5 3.5 10.5H5.5"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>
