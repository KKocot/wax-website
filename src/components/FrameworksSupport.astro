---
import { siNodedotjs, siReact, siVuedotjs, siNextdotjs, siNuxt, siVite, siWebpack, siRollupdotjs } from "simple-icons";

const frameworks = [
  {
    name: "Node.js",
    url: "https://nodejs.org",
    brandColor: `#${siNodedotjs.hex}`,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="${siNodedotjs.path}"/></svg>`,
  },
  {
    name: "React",
    url: "https://react.dev",
    brandColor: `#${siReact.hex}`,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="${siReact.path}"/></svg>`,
  },
  {
    name: "Vue.js",
    url: "https://vuejs.org",
    brandColor: `#${siVuedotjs.hex}`,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="${siVuedotjs.path}"/></svg>`,
  },
  {
    name: "Next.js",
    url: "https://nextjs.org",
    brandColor: "#ffffff",
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="${siNextdotjs.path}"/></svg>`,
  },
  {
    name: "Nuxt",
    url: "https://nuxt.com",
    brandColor: `#${siNuxt.hex}`,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="${siNuxt.path}"/></svg>`,
  },
  {
    name: "Vite",
    url: "https://vite.dev",
    brandColor: `#${siVite.hex}`,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="${siVite.path}"/></svg>`,
  },
  {
    name: "Webpack",
    url: "https://webpack.js.org",
    brandColor: `#${siWebpack.hex}`,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="${siWebpack.path}"/></svg>`,
  },
  {
    name: "Rollup",
    url: "https://rollupjs.org",
    brandColor: `#${siRollupdotjs.hex}`,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="${siRollupdotjs.path}"/></svg>`,
  },
];
---

<section id="frameworks" class="min-h-screen flex flex-col items-center justify-center py-16 max-md:py-12" aria-labelledby="frameworks-heading">
  <div class="mx-auto max-w-[1120px] px-6">
    <h2
      id="frameworks-heading"
      data-animate
      class="font-display text-[2.5rem] max-md:text-[1.75rem] leading-[1.2] text-text-primary text-center mb-4"
    >
      Works everywhere
    </h2>
    <p
      data-animate
      class="text-text-secondary text-[0.9375rem] leading-[1.6] text-center max-w-2xl mx-auto mb-16"
    >
      Imports automatically resolve to either web or node.js version based on
      your execution environment &mdash; helpful in SSR scenarios.
    </p>
    <div class="flex flex-wrap items-start justify-center gap-x-10 gap-y-8 max-md:gap-x-6 max-md:gap-y-6">
      {frameworks.map((fw, i) => (
        <a
          href={fw.url}
          target="_blank"
          rel="noopener noreferrer"
          data-animate
          data-brand-color={fw.brandColor}
          style={`transition-delay: ${i * 60}ms; --brand: ${fw.brandColor}`}
          class:list={[
            "group flex flex-col items-center gap-2.5 no-underline",
            "transition-transform duration-200 ease-out",
            "hover:scale-105 focus-visible:scale-105",
            "w-[4.5rem]",
          ]}
        >
          <span
            class:list={[
              "flex items-center justify-center",
              "w-12 h-12",
              "text-text-tertiary",
              "transition-colors duration-200 ease-out",
              "group-hover:text-[var(--brand)] group-focus-visible:text-[var(--brand)]",
            ]}
            set:html={fw.icon}
          />
          <span
            class:list={[
              "font-display text-[0.75rem] leading-tight text-text-tertiary text-center",
              "transition-colors duration-200 ease-out",
              "group-hover:text-text-primary group-focus-visible:text-text-primary",
            ]}
          >
            {fw.name}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
